{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "paths": {
      "@shelfchef/shared": ["./packages/shared/src/index.ts"]
    }
  },
  "include": [
    "packages/shared/src/**/*.ts",
    "packages/shared/tests/**/*.ts",
    "packages/shared/vitest.config.ts",
    "apps/api/src/**/*.ts",
    "apps/api/tests/**/*.ts",
    "apps/api/vitest.config.ts",
    "apps/web/src/**/*.ts",
    "apps/web/src/**/*.tsx",
    "apps/web/tests/**/*.ts",
    "apps/web/tests/**/*.tsx",
    "apps/web/vite.config.ts",
    "e2e/**/*.ts",
    "vitest.workspace.ts",
    "playwright.config.ts"
  ]
}
